      "title": "🚨 Signals by Risk Level",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT risk_level, COUNT(*) as count FROM signals GROUP BY risk_level",
          "format": "table"
        }
      ]
    },
    {
      "title": "💰 Volume by Blockchain",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT blockchain, SUM(amount_usd) as total_usd FROM whale_events GROUP BY blockchain",
          "format": "table"
        }
      ]
    },
    {
      "title": "🏦 Exchange Deposits",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "rawSql": "SELECT detected_at, blockchain, amount, amount_usd, exchange_name, from_address FROM whale_events WHERE is_exchange_deposit = 1 ORDER BY id DESC LIMIT 50",
          "format": "table"
        }
      ]
    },
    {
      "title": "📊 Recent Signals",
